import speech_recognition as sr
import pyttsx3
import datetime
import wikipedia
import pyjokes
import webbrowser

engine = pyttsx3.init()

def speak(text):
    engine.say(text)
    engine.runAndWait()

def take_command():
    recognizer = sr.Recognizer()
    with sr.Microphone() as source:
        print("Listening...")
        audio = recognizer.listen(source)
    try:
        query = recognizer.recognize_google(audio)
        print(f"User said: {query}\n")
    except Exception:
        return "None"
    return query.lower()

def run_assistant():
    while True:
        query = take_command()
        if 'wikipedia' in query:
            speak(wikipedia.summary(query.replace("wikipedia", ""), sentences=1))
        elif 'joke' in query:
            speak(pyjokes.get_joke())
        elif 'exit' in query:
            break

if __name__ == "__main__":
    run_assistant()
